SECTION 2 — BACKEND .env (production values)
════════════════════════════════════════════════════════════════════════════════

File location on server: C:\sas-relay\backend\.env

Fill in every value before transferring:

    # Database
    DATABASE_URL=postgresql://sas_relay_user:<DB_PASSWORD>@<DB_HOST>:5432/sas_relay

    # Session signing — paste output from Section 1.2
    SECRET_KEY=<64_CHAR_HEX_STRING>

    # SAML
    SAML_SP_ENTITY_ID=https://<YOUR_DOMAIN>
    SAML_IDP_METADATA_URL=https://<IDP_HOST>/metadata
    SAML_SP_PRIVATE_KEY_FILE=C:\sas-relay\backend\saml\sp_private.pem
    SAML_SP_CERT_FILE=C:\sas-relay\backend\saml\sp_cert.pem

    # CORS — must match your production domain exactly
    ALLOWED_ORIGINS=https://<YOUR_DOMAIN>

    # Session
    SESSION_EXPIRE_HOURS=8

    # Rate limiting
    RATE_LIMIT_CHECK=100/hour

    # Environment — enables production mode, disables /docs
    ENVIRONMENT=production

    # Active Directory LDAP
    LDAP_SERVER=ldap://<DC_HOST>.<YOURCOMPANY>.internal
    LDAP_BIND_DN=CN=<SERVICE_ACCOUNT>,OU=Service Accounts,DC=<CORP>,DC=com
    LDAP_BIND_PASSWORD=<SERVICE_ACCOUNT_PASSWORD>
    LDAP_BASE_DN=DC=<CORP>,DC=com


