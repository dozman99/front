# =============================================================================
# SAS RELAY BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# Never commit .env to git
# =============================================================================

# PostgreSQL connection string
# Remote server on internal network — NOT localhost
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://sas_relay_user:CHANGE_ME@DB_SERVER_HOST:5432/sas_relay

# Session signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING

# SAML SSO settings
SAML_SP_ENTITY_ID=https://sas-relay.yourcompany.internal
SAML_IDP_METADATA_URL=https://secds.yourcompany.internal/metadata
SAML_SP_PRIVATE_KEY_FILE=./saml/sp_private.pem
SAML_SP_CERT_FILE=./saml/sp_cert.pem

# CORS — comma separated list of allowed origins
ALLOWED_ORIGINS=https://sas-relay.yourcompany.internal

# Session expiry in hours
SESSION_EXPIRE_HOURS=8

# Rate limit for public /check endpoints
RATE_LIMIT_CHECK=100/hour

# Environment: development or production
# production disables /docs endpoint
ENVIRONMENT=production

# Active Directory LDAP sync (used by /groups/sync)
# Service account with read access to group objects
LDAP_SERVER=ldap://dc.yourcompany.internal
LDAP_BIND_DN=CN=svc-sas-relay,OU=Service Accounts,DC=corp,DC=com
LDAP_BIND_PASSWORD=CHANGE_ME
LDAP_BASE_DN=DC=corp,DC=com
